# Usar pooler (puerto 6543) con connection_limit para evitar timeout
DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres"
JWT_SECRET="cambia-este-secret-en-produccion"
JWT_EXPIRES_IN="7d"
JWT_PORTAL_SECRET="cambia-este-secret-portal-en-produccion"
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:3001"

# Mercado Pago (Checkout Pro - portal inquilinos)
MP_ACCESS_TOKEN=""

# Email (Gmail SMTP por defecto)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="tu-email@gmail.com"
MAIL_PASS="tu-app-password"
MAIL_FROM="\"Sistema Inmobiliario\" <tu-email@gmail.com>"

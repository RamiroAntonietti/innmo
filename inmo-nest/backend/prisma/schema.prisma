// ============================================
// PRISMA SCHEMA - Inmobiliaria SaaS Multi-tenant
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SUBSCRIPTION PLAN ───────────────────────
model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   @unique
  priceMonthly    Int      @map("price_monthly")
  maxProperties   Int?     @map("max_properties")
  maxUsers        Int?     @map("max_users")
  enabledModules  Json     @map("enabled_modules")
  createdAt       DateTime @default(now()) @map("created_at")

  tenants         Tenant[]

  @@map("subscription_plans")
}

// ─── TENANT (Inmobiliaria) ───────────────────
model Tenant {
  id                  String    @id @default(uuid())
  nombre              String
  email               String    @unique
  telefono            String?
  planId              String?   @map("plan_id")
  subscriptionStatus  String    @default("ACTIVE") @map("subscription_status")
  subscriptionStart   DateTime? @map("subscription_start")
  subscriptionEnd     DateTime? @map("subscription_end")
  activo              Boolean   @default(true)
  // Datos fiscales (emisor - para facturación electrónica AFIP/ARCA)
  cuit                String?
  razonSocial         String?   @map("razon_social")
  condicionIva        String?   @map("condicion_iva")
  domicilioFiscal     String?   @map("domicilio_fiscal")
  puntoVenta          Int?      @map("punto_venta")
  comisionPorcentajeAlquiler Decimal? @map("comision_porcentaje_alquiler") @db.Decimal(5, 2)
  // Configuración
  logoUrl             String?   @map("logo_url")
  direccion           String?
  sitioWeb            String?   @map("sitio_web")
  mpAccessToken       String?   @map("mp_access_token")
  mpPublicKey         String?   @map("mp_public_key")
  mlAppId             String?   @map("ml_app_id")
  mlClientId          String?   @map("ml_client_id")
  mlClientSecret      String?   @map("ml_client_secret")
  mlAccessToken       String?   @map("ml_access_token")
  mlRefreshToken      String?   @map("ml_refresh_token")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  plan        SubscriptionPlan? @relation(fields: [planId], references: [id])

  usuarios    Usuario[]
  clientes    Cliente[]
  propiedades Propiedad[]
  contratos   ContratoAlquiler[]
  operaciones OperacionVenta[]
  gastos      GastoPropiedad[]
  tareas      Tarea[]
  facturas    FacturaServicio[]
  facturasEmitidas FacturaEmitida[]
  imagenes    PropiedadImagen[]
  portalAccesos PortalAcceso[]
  consultasPortal ConsultaPortal[]
  inventarioItems InventarioItem[]
  presupuestos Presupuesto[]
  propiedadesMercadoLibre PropiedadMercadoLibre[]

  @@map("tenants")
}

// ─── USUARIO ────────────────────────────────
model Usuario {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  nombre        String
  apellido      String
  email         String
  password      String
  rol           Rol       @default(AGENTE)
  activo        Boolean   @default(true)
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operaciones OperacionVenta[] @relation("AgenteOperacion")
  tareas      Tarea[]

  @@unique([tenantId, email])
  @@map("usuarios")
}

enum Rol {
  ADMIN
  AGENTE
  ASISTENTE
}

// ─── CLIENTE (CRM) ──────────────────────────
model Cliente {
  id         String        @id @default(uuid())
  tenantId   String        @map("tenant_id")
  codigo     String?       @unique
  nombre     String
  apellido   String
  telefono   String?
  email      String?
  tipo       TipoCliente
  estado     EstadoCliente @default(PROSPECTO)
  notas      String?
  // Datos fiscales (receptor - para facturación electrónica)
  cuit               String?
  razonSocial        String?   @map("razon_social")
  condicionIva       String?   @map("condicion_iva")
  domicilioFiscal    String?   @map("domicilio_fiscal")
  requiereFactura    Boolean   @default(false) @map("requiere_factura")
  deletedAt  DateTime?     @map("deleted_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedades   Propiedad[]        @relation("PropietarioPropiedad")
  contratos     ContratoAlquiler[]  @relation("InquilinoContrato")
  operaciones   OperacionVenta[]   @relation("CompradorOperacion")
  interacciones Interaccion[]
  tareas        Tarea[]
  facturasEmitidas FacturaEmitida[]
  portalAcceso     PortalAcceso?
  consultasPortal  ConsultaPortal[]
  presupuestos     Presupuesto[]

  @@map("clientes")
}

// ─── PORTAL ACCESO (inquilinos/propietarios) ───
model PortalAcceso {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  clienteId  String   @unique @map("cliente_id")
  email      String
  password   String
  rol        RolPortal @default(INQUILINO)
  activo     Boolean  @default(true)
  primerLogin Boolean @default(true) @map("primer_login")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("portal_accesos")
}

// ─── CONSULTA PORTAL (mensajes de inquilinos/propietarios) ───
model ConsultaPortal {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  clienteId  String    @map("cliente_id")
  rol        RolPortal
  mensaje    String
  leido      Boolean   @default(false)
  respuesta  String?
  respuestaAt DateTime? @map("respuesta_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("consultas_portal")
}

enum RolPortal {
  INQUILINO
  PROPIETARIO
}

enum TipoCliente {
  COMPRADOR
  VENDEDOR
  INQUILINO
  PROPIETARIO
}

enum EstadoCliente {
  ACTIVO
  INACTIVO
  PROSPECTO
  CERRADO
}

// ─── INTERACCIÓN (Historial CRM) ────────────
model Interaccion {
  id          String   @id @default(uuid())
  clienteId   String   @map("cliente_id")
  tipo        String
  descripcion String
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("interacciones")
}

// ─── PROPIEDAD ───────────────────────────────
model Propiedad {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  codigo          String?         @unique
  titulo          String
  descripcion     String?
  direccion       String
  ciudad          String
  precio          Decimal         @db.Decimal(12, 2)
  tipoOperacion   TipoOperacion   @map("tipo_operacion")
  estado          EstadoPropiedad @default(DISPONIBLE)
  dormitorios     Int?
  banos           Int?            @map("banos")
  metrosCuadrados Decimal?        @map("metros_cuadrados") @db.Decimal(8, 2)
  propietarioId   String?         @map("propietario_id")
  amueblada       Boolean         @default(false)
  deletedAt       DateTime?       @map("deleted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propietario Cliente?           @relation("PropietarioPropiedad", fields: [propietarioId], references: [id])
  contratos   ContratoAlquiler[]
  operaciones OperacionVenta[]
  gastos      GastoPropiedad[]
  tareas      Tarea[]
  facturas    FacturaServicio[]
  imagenes    PropiedadImagen[]
  inventario  InventarioItem[]
  presupuestosPropiedad PresupuestoPropiedad[]
  mercadoLibre PropiedadMercadoLibre?

  @@map("propiedades")
}

// ─── INVENTARIO (propiedades amuebladas) ─────
model InventarioItem {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  propiedadId  String   @map("propiedad_id")
  nombre       String
  cantidad     Int      @default(1)
  estado       EstadoInventario @default(BUENO)
  observaciones String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)

  @@map("inventario_items")
}

enum EstadoInventario {
  BUENO
  REGULAR
  DETERIORADO
}

// ─── PRESUPUESTO ─────────────────────────────
model Presupuesto {
  id           String           @id @default(uuid())
  tenantId     String           @map("tenant_id")
  codigo       String?          @unique
  clienteId    String           @map("cliente_id")
  tipo         TipoPresupuesto
  montoTotal   Decimal          @map("monto_total") @db.Decimal(12, 2)
  vigenciaHasta DateTime        @map("vigencia_hasta")
  estado      EstadoPresupuesto @default(BORRADOR)
  notas       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente  Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propiedades PresupuestoPropiedad[]

  @@map("presupuestos")
}

model PresupuestoPropiedad {
  id            String     @id @default(uuid())
  presupuestoId String     @map("presupuesto_id")
  propiedadId   String     @map("propiedad_id")
  monto         Decimal    @db.Decimal(12, 2)
  createdAt     DateTime   @default(now()) @map("created_at")

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  propiedad   Propiedad   @relation(fields: [propiedadId], references: [id], onDelete: Cascade)

  @@unique([presupuestoId, propiedadId])
  @@map("presupuestos_propiedad")
}

enum TipoPresupuesto {
  ALQUILER
  VENTA
}

enum EstadoPresupuesto {
  BORRADOR
  ENVIADO
  ACEPTADO
  RECHAZADO
}

enum TipoOperacion {
  VENTA
  ALQUILER
}

enum EstadoPropiedad {
  DISPONIBLE
  RESERVADO
  VENDIDO
  ALQUILADO
}

// ─── CONTRATO ALQUILER ───────────────────────
model ContratoAlquiler {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  codigo           String?        @unique
  propiedadId      String         @map("propiedad_id")
  inquilinoId      String         @map("inquilino_id")
  fechaInicio      DateTime       @map("fecha_inicio")
  fechaFin         DateTime       @map("fecha_fin")
  montoMensual     Decimal        @map("monto_mensual") @db.Decimal(12, 2)
  deposito         Decimal?       @db.Decimal(12, 2)
  depositoEstado   EstadoDeposito? @map("deposito_estado")
  depositoDevueltoAt DateTime?    @map("deposito_devuelto_at")
  depositoNotas    String?        @map("deposito_notas")
  estado           EstadoContrato @default(ACTIVO)
  tipoAjuste       TipoAjuste?    @map("tipo_ajuste")
  frecuenciaAjuste Int?           @map("frecuencia_ajuste")
  porcentajeAjuste Decimal?       @map("porcentaje_ajuste") @db.Decimal(6, 2)
  proximoAjuste    DateTime?      @map("proximo_ajuste")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad        Propiedad         @relation(fields: [propiedadId], references: [id])
  inquilino        Cliente           @relation("InquilinoContrato", fields: [inquilinoId], references: [id])
  pagos            PagoAlquiler[]
  historialAjustes HistorialAjuste[]

  @@map("contratos_alquiler")
}

enum EstadoContrato {
  ACTIVO
  FINALIZADO
  ATRASADO
  ANULADO
}

enum EstadoDeposito {
  PENDIENTE
  DEVUELTO
  RETENIDO
}

enum TipoAjuste {
  FIJO
  IPC
}

// ─── HISTORIAL DE AJUSTES ────────────────────
model HistorialAjuste {
  id            String     @id @default(uuid())
  contratoId    String     @map("contrato_id")
  fechaAjuste   DateTime   @map("fecha_ajuste")
  montoAnterior Decimal    @map("monto_anterior") @db.Decimal(12, 2)
  montoNuevo    Decimal    @map("monto_nuevo") @db.Decimal(12, 2)
  porcentaje    Decimal    @db.Decimal(6, 2)
  tipoAjuste    TipoAjuste @map("tipo_ajuste")
  detalle       String?
  createdAt     DateTime   @default(now()) @map("created_at")

  contrato ContratoAlquiler @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@map("historial_ajustes")
}

// ─── PAGO ALQUILER ───────────────────────────
model PagoAlquiler {
  id          String     @id @default(uuid())
  codigo      String?    @unique
  contratoId  String     @map("contrato_id")
  fechaVence   DateTime   @map("fecha_vence")  // Fecha de vencimiento de la cuota
  fechaPago   DateTime?  @map("fecha_pago")   // Fecha efectiva del pago (solo cuando está pagado)
  monto       Decimal    @db.Decimal(12, 2)
  montoPagado Decimal?   @map("monto_pagado") @db.Decimal(12, 2)
  estado      EstadoPago @default(PENDIENTE)
  formaPago   FormaPago? @map("forma_pago")
  tipoPago    TipoPago   @default(COMPLETO) @map("tipo_pago")
  notas       String?
  createdAt   DateTime   @default(now()) @map("created_at")

  contrato ContratoAlquiler @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  mpPago   PagoMercadoPago?

  @@map("pagos_alquiler")
}

// ─── PAGO MERCADO PAGO (Checkout Pro) ─────────
model PagoMercadoPago {
  id             String   @id @default(uuid())
  pagoAlquilerId String   @unique @map("pago_alquiler_id")
  preferenceId   String   @map("preference_id")
  paymentId      String?  @map("payment_id")
  status         String   @default("pending") // pending, approved, rejected, cancelled
  initPoint      String?  @map("init_point")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  pagoAlquiler PagoAlquiler @relation(fields: [pagoAlquilerId], references: [id], onDelete: Cascade)

  @@map("pagos_mercado_pago")
}

enum EstadoPago {
  PAGADO
  PENDIENTE
  ATRASADO
  PARCIAL
}

enum FormaPago {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
  TARJETA
  MERCADOPAGO
}

enum TipoPago {
  COMPLETO
  PARCIAL
}

// ─── OPERACIÓN VENTA ─────────────────────────
model OperacionVenta {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  codigo      String?     @unique
  propiedadId String      @map("propiedad_id")
  compradorId String      @map("comprador_id")
  agenteId    String?     @map("agente_id")
  precioFinal Decimal     @map("precio_final") @db.Decimal(12, 2)
  comision    Decimal     @db.Decimal(12, 2)
  estado      EstadoVenta @default(NEGOCIACION)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad Propiedad @relation(fields: [propiedadId], references: [id])
  comprador Cliente   @relation("CompradorOperacion", fields: [compradorId], references: [id])
  agente    Usuario?  @relation("AgenteOperacion", fields: [agenteId], references: [id])

  @@map("operaciones_venta")
}

enum EstadoVenta {
  NEGOCIACION
  FIRMADO
  ESCRITURADO
}

// ─── GASTO PROPIEDAD ─────────────────────────
model GastoPropiedad {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  codigo      String?   @unique
  propiedadId String    @map("propiedad_id")
  tipo        TipoGasto
  descripcion String
  monto       Decimal   @db.Decimal(12, 2)
  fecha       DateTime
  pagadoPor   PagadoPor @default(PROPIETARIO) @map("pagado_por")
  comprobante String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)

  @@map("gastos_propiedad")
}

enum TipoGasto {
  REPARACION
  IMPUESTO
  EXPENSA
  SEGURO
  SERVICIO
  HONORARIO
  OTRO
}

enum PagadoPor {
  PROPIETARIO
  INMOBILIARIA
}

// ─── TAREA ───────────────────────────────────
model Tarea {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  usuarioId   String      @map("usuario_id")
  titulo      String
  descripcion String?
  tipo        TipoTarea
  prioridad   Prioridad   @default(MEDIA)
  estado      EstadoTarea @default(PENDIENTE)
  fechaVence  DateTime?   @map("fecha_vence")
  clienteId   String?     @map("cliente_id")
  propiedadId String?     @map("propiedad_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario   Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id])
  propiedad Propiedad? @relation(fields: [propiedadId], references: [id])

  @@map("tareas")
}

enum TipoTarea {
  SEGUIMIENTO_CLIENTE
  VISITA_PROPIEDAD
  LLAMADA
  VENCIMIENTO_CONTRATO
  PAGO_PENDIENTE
  GENERAL
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

enum EstadoTarea {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

// ─── FACTURA SERVICIO ─────────────────────────
model FacturaServicio {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  propiedadId  String        @map("propiedad_id")
  tipoServicio TipoServicio  @map("tipo_servicio")
  monto        Decimal       @db.Decimal(12, 2)
  fechaVence   DateTime      @map("fecha_vence")
  estado       EstadoFactura @default(PENDIENTE)
  notas        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)

  @@map("facturas_servicio")
}

enum TipoServicio {
  LUZ
  GAS
  AGUA
  INTERNET
  EXPENSAS
  TELEFONO
  OTRO
}

enum EstadoFactura {
  PENDIENTE
  PAGADO
  VENCIDO
}

// ─── FACTURA EMITIDA (a clientes - preparado para AFIP/ARCA) ───
model FacturaEmitida {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  clienteId        String   @map("cliente_id")
  codigo           String?  @unique
  tipoComprobante  String   @map("tipo_comprobante") // A, B, C, etc.
  puntoVenta       Int      @map("punto_venta")
  numero           Int?     // Número asignado por AFIP
  fechaEmision     DateTime @map("fecha_emision")
  concepto         Int      @default(2) // 1=productos, 2=servicios, 3=mixto
  descripcion      String?
  montoNeto        Decimal  @map("monto_neto") @db.Decimal(12, 2)
  montoIva         Decimal  @map("monto_iva") @db.Decimal(12, 2) @default(0)
  montoTotal       Decimal  @map("monto_total") @db.Decimal(12, 2)
  // Respuesta AFIP (cuando se implemente)
  cae              String?
  fechaVencimientoCae DateTime? @map("fecha_vencimiento_cae")
  estado           String   @default("BORRADOR") // BORRADOR, PENDIENTE_AFIP, AUTORIZADA, RECHAZADA, ANULADA
  errorAfip        String?  @map("error_afip")
  operacionVentaId String?  @map("operacion_venta_id") // Opcional: factura por comisión
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)

  @@map("facturas_emitidas")
}

// ─── PROPIEDAD MERCADO LIBRE (publicación en ML) ───
model PropiedadMercadoLibre {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  propiedadId String   @unique @map("propiedad_id")
  mlItemId    String   @map("ml_item_id")
  mlPermalink String?  @map("ml_permalink")
  mlStatus    String?  @map("ml_status")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)

  @@map("propiedades_mercado_libre")
}

// ─── IMAGEN PROPIEDAD ─────────────────────────
model PropiedadImagen {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  propiedadId String   @map("propiedad_id")
  url         String
  nombre      String?
  orden       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)

  @@map("propiedades_imagenes")
}

// ─── AUDIT LOG ────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  usuarioId String?  @map("usuario_id")
  accion    String
  entidad   String
  entidadId String?  @map("entidad_id")
  detalle   Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
